# =============================================================================
# FRONTEND .gitignore — Next.js specific
# =============================================================================
# Auto-generated by create-next-app. This file handles patterns specific to
# the Next.js/Node.js frontend that the root .gitignore doesn't cover.
# Git .gitignore files are additive — this works alongside the root one.
# See https://help.github.com/articles/ignoring-files/
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
# /node_modules — same as root, but with leading "/" so it only matches the
#   node_modules in THIS directory (not nested ones).
# .pnp.* and .yarn/* — Yarn's "Plug'n'Play" mode stores dependencies
#   differently than node_modules. The "!" lines are exceptions that UN-ignore
#   specific .yarn subfolders that SHOULD be committed (patches, plugins, etc.).
# -----------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# /coverage — generated by test runners (Jest, Vitest) when you run tests
#   with coverage reporting. Contains HTML reports and raw coverage data.
#   Reproducible by re-running tests.
# -----------------------------------------------------------------------------
/coverage

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
# .next/ — Next.js build cache and compiled output (pages, chunks, etc.).
#   Regenerated every time you run "next build" or "next dev".
# /out/ — static HTML export output when using "next export".
# -----------------------------------------------------------------------------
/.next/
/out/

# -----------------------------------------------------------------------------
# Production build
# -----------------------------------------------------------------------------
# /build — alternative production build output folder.
# -----------------------------------------------------------------------------
/build

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# .DS_Store — macOS Finder metadata (also covered by root .gitignore).
# *.pem — SSL/TLS certificate and private key files. These are secrets used
#   for HTTPS in local development. Never commit private keys.
# -----------------------------------------------------------------------------
.DS_Store
*.pem

# -----------------------------------------------------------------------------
# Debug logs
# -----------------------------------------------------------------------------
# Package managers (npm, yarn, pnpm) create these log files when errors occur
# during install or build. They contain local file paths and are only useful
# for debugging on the machine that generated them.
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Environment variables (SECURITY-CRITICAL)
# -----------------------------------------------------------------------------
# .env* matches ALL files starting with ".env" — covers .env, .env.local,
#   .env.development, .env.production, etc. This is the broadest pattern
#   and ensures no env file variant accidentally slips through.
# This is where NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#   and NEXT_PUBLIC_FASTAPI_URL live. Do not commit these.
# -----------------------------------------------------------------------------
.env*

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
# .vercel/ — local Vercel CLI configuration and project linking metadata.
#   Contains project IDs and settings specific to your Vercel account.
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
# *.tsbuildinfo — TypeScript's incremental compilation cache. Speeds up
#   rebuilds but is machine-specific and fully reproducible.
# next-env.d.ts — auto-generated by Next.js to declare TypeScript types
#   for Next.js features. Regenerated on every build, so no need to track it.
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts
